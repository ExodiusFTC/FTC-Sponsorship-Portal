# ─── Supabase ────────────────────────────────────────────────────────────────
# Project REST URL, e.g. https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
# Publishable (anon) key — new format: sb_publishable_... (or legacy anon JWT)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Secret (service-role) key — new format: sb_secret_... (or legacy service_role JWT)
# SERVER-ONLY. Never expose to the browser. Bypasses all RLS.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── Resend (transactional email) ────────────────────────────────────────────
RESEND_API_KEY=your_resend_api_key
# Must be a verified sending domain. In production this MUST start with "noreply@".
RESEND_FROM_EMAIL=noreply@yourdomain.com
# Svix signing secret for the Resend webhook. REQUIRED in production.
RESEND_WEBHOOK_SECRET=your_resend_webhook_secret

# ─── Upstash Redis (rate limiting) — OPTIONAL ────────────────────────────────
# Leave BLANK to skip entirely. Rate limiting fails open (passes requests through)
# when unset, so the app works fine without it. To enable brute-force protection
# later, just set both values — no code changes needed.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── App ─────────────────────────────────────────────────────────────────────
# Public base URL of the deployment, e.g. https://yourdomain.com (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional: comma-separated admin emails for system alerts.
# If unset, alerts fall back to a profiles.role='admin' lookup.
ADMIN_NOTIFICATION_EMAILS=

# ─── Sentry (optional error monitoring) ──────────────────────────────────────
SENTRY_DSN=your_sentry_dsn
# Public DSN for client-side error capture (safe to expose; can equal SENTRY_DSN)
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn

# ─── Cron ────────────────────────────────────────────────────────────────────
# Shared secret for the daily Vercel cron (/api/cron/expire-submissions). REQUIRED.
# Vercel automatically sends this as the Bearer token for scheduled cron invocations.
CRON_SECRET=your_cron_secret
